@echo off
setlocal
on break gosub fc_cleanup
::
:: designer-integration.btm -- Integration tests for the visual designer
:: =====================================================================
::
:: Tests toolbar buttons, menu items, and context menu actions by
:: simulating clicks via @FORMSIMULATE and verifying results with
:: @FORMGET. Each test creates a known initial state, triggers an
:: action, and checks the outcome.
::
:: Usage:
::   set FORMCAST_DLL=path\to\FormCast.dll
::   call tests\designer-integration.btm
::
:: timeout=120
::

set REPO=%@full[%_batchpath\..]
set PASS=0
set FAIL=0
set TOTAL=0

call "%REPO\examples\formcast-check.btm" load

:: Enable debug logging to the test folder
set RC=%@formlog[debug,%_batchpath\designer-integration.log]

echo FormCast v%@formversion[] -- Designer Integration Tests
echo ============================================================
echo.

:: ==================== Setup ====================
:: Load the three designer windows from templates
set hCanvas=%@formopen[form,test_canvas,0,0,500,420]
set RC=%@formset[%hCanvas,.,title,Test Canvas]
set RC=%@formset[%hCanvas,.,design_mode,1]

set hTool=%@formload[%REPO\examples\designer\templates\toolbox.jsonc]
set hProps=%@formload[%REPO\examples\designer\templates\properties.jsonc]

set RC=%@formset[%hCanvas,.,confirmclose,1]
set RC=%@formset[%hTool,.,confirmclose,1]
set RC=%@formset[%hProps,.,confirmclose,1]

set RC=%@formshow[%hCanvas]
set RC=%@formshow[%hTool]
set RC=%@formshow[%hProps]

:: Attach context menu from toolbox to canvas
set RC=%@formset[%hCanvas,.,runtimecontextmenu,%hTool:ctxMenu]

:: ==================== Helper subroutines ====================
goto :start_tests

:add_test_controls
  :: Add 3 controls at known positions
  set RC=%@formadd[%hCanvas,Label1,LABEL,20,20,100,20,Label]
  set RC=%@formadd[%hCanvas,Edit1,EDIT,40,60,150,24,]
  set RC=%@formadd[%hCanvas,Button1,BUTTON,80,100,80,28,Button]
return

:clear_canvas
  :: Remove all controls by closing and recreating the canvas
  set RC=%@formclose[%hCanvas]
  set hCanvas=%@formopen[form,test_canvas,0,0,500,420]
  set RC=%@formset[%hCanvas,.,title,Test Canvas]
  set RC=%@formset[%hCanvas,.,design_mode,1]
  set RC=%@formset[%hCanvas,.,confirmclose,1]
  set RC=%@formshow[%hCanvas]
  set RC=%@formset[%hCanvas,.,runtimecontextmenu,%hTool:ctxMenu]
return

:check
  :: Usage: set _tname=test name & set _expect=expected & set _actual=actual & gosub check
  set /a TOTAL=%TOTAL + 1
  iff "%_actual" == "%_expect" then
    set /a PASS=%PASS + 1
    echo   PASS: %_tname
  else
    set /a FAIL=%FAIL + 1
    echo   FAIL: %_tname (expected=[%_expect] actual=[%_actual])
  endiff
return

:start_tests

:: ==================== Test: controllist JSON ====================
echo --- controllist ---
gosub add_test_controls
set _json=%@formget[%hCanvas,.,controllist]
set _jrc=%@jsoninput[%_json]
set _jn=%@jsonnodes[/json/items/]

set _tname=controllist returns 3 items
set _expect=3
set _actual=%_jn
gosub check

set _tname=controllist first id is Label1
set _expect=Label1
set _actual=%@unquote[%@jsonxpath[/json/items/[1]/id/]]
gosub check

set _tname=controllist first type is LABEL
set _expect=LABEL
set _actual=%@unquote[%@jsonxpath[/json/items/[1]/type/]]
gosub check

set _tname=controllist third id is Button1
set _expect=Button1
set _actual=%@unquote[%@jsonxpath[/json/items/[3]/id/]]
gosub check

set _jrc=%@jsonreset[]
echo.

:: ==================== Test: Multi-select properties ====================
echo --- multi-select ---
:: Select Label1, then Ctrl+click Edit1
set RC=%@formsimulate[%hCanvas,Label1,mousedown,10:10]
set RC=%@formsimulate[%hCanvas,Label1,mouseup,10:10]
delay /m 200

set _tname=single select shows Label1
set _expect=Label1
set _actual=%@formget[%hCanvas,.,selected]
gosub check

set _tname=selectioncount is 1
set _expect=1
set _actual=%@formget[%hCanvas,.,selectioncount]
gosub check
echo.

:: ==================== Test: Toolbar buttons fire events ====================
echo --- toolbar click events ---
gosub clear_canvas
gosub add_test_controls

:: Click tbDelete on toolbox -- should enqueue a click event
set RC=%@formsimulate[%hTool,tbDelete,click]
delay /m 200

:: Drain events and check for tbDelete
set _found_tbDelete=0
do ev in /p formevents %hTool
  set _ctrl=%@word[2,%ev]
  if "%_ctrl" == "tbDelete" set _found_tbDelete=1
enddo

set _tname=tbDelete click fires event
set _expect=1
set _actual=%_found_tbDelete
gosub check

:: Click tbCopy
set RC=%@formsimulate[%hTool,tbCopy,click]
delay /m 200
set _found_tbCopy=0
do ev in /p formevents %hTool
  set _ctrl=%@word[2,%ev]
  if "%_ctrl" == "tbCopy" set _found_tbCopy=1
enddo

set _tname=tbCopy click fires event
set _expect=1
set _actual=%_found_tbCopy
gosub check

:: Click tbPaste
set RC=%@formsimulate[%hTool,tbPaste,click]
delay /m 200
set _found_tbPaste=0
do ev in /p formevents %hTool
  set _ctrl=%@word[2,%ev]
  if "%_ctrl" == "tbPaste" set _found_tbPaste=1
enddo

set _tname=tbPaste click fires event
set _expect=1
set _actual=%_found_tbPaste
gosub check

:: Click tbUndo
set RC=%@formsimulate[%hTool,tbUndo,click]
delay /m 200
set _found_tbUndo=0
do ev in /p formevents %hTool
  set _ctrl=%@word[2,%ev]
  if "%_ctrl" == "tbUndo" set _found_tbUndo=1
enddo

set _tname=tbUndo click fires event
set _expect=1
set _actual=%_found_tbUndo
gosub check

:: Click tbRedo
set RC=%@formsimulate[%hTool,tbRedo,click]
delay /m 200
set _found_tbRedo=0
do ev in /p formevents %hTool
  set _ctrl=%@word[2,%ev]
  if "%_ctrl" == "tbRedo" set _found_tbRedo=1
enddo

set _tname=tbRedo click fires event
set _expect=1
set _actual=%_found_tbRedo
gosub check
echo.

