:: ==================== Test: @FORMLOG ====================
echo --- @FORMLOG ---
set _logfile=%TEMP\fc_test_log.txt
if exist "%_logfile" del /q "%_logfile"

set RC=%@formlog[debug,%_logfile]
set _tname=@FORMLOG returns 0
set _expect=0
set _actual=%RC
gosub check

:: Trigger a logged action
set RC=%@formset[%hCanvas,Label1,position,10:10]
set RC=%@formlog[off]

iff exist "%_logfile" then
  set _tname=log file created
  set _expect=1
  set _actual=1
  gosub check
else
  set _tname=log file created
  set _expect=1
  set _actual=0
  gosub check
endiff
if exist "%_logfile" del /q "%_logfile"
echo.

:: ==================== Test: @FORMSAVEIMAGE ====================
echo --- @FORMSAVEIMAGE ---
set _imgfile=%TEMP\fc_test_image.png
if exist "%_imgfile" del /q "%_imgfile"

set RC=%@formsaveimage[%hCanvas,%_imgfile]
set _tname=@FORMSAVEIMAGE returns 0
set _expect=0
set _actual=%RC
gosub check

iff exist "%_imgfile" then
  set _tname=image file created
  set _expect=1
  set _actual=1
  gosub check
else
  set _tname=image file created
  set _expect=1
  set _actual=0
  gosub check
endiff
if exist "%_imgfile" del /q "%_imgfile"
echo.

:: ==================== Test: Copy/Paste simple control ====================
echo --- copy/paste simple ---
gosub clear_canvas
gosub add_test_controls

:: Copy Label1
set RC=%@formset[%hCanvas,.,clipcopy,Label1]

set _tname=canvas has 3 controls before paste
set _expect=3
set _actual=%@formget[%hCanvas,.,controls]
gosub check

:: Paste
set RC=%@formset[%hCanvas,.,clippaste,]

set _tname=canvas has 4 controls after paste
set _expect=4
set _actual=%@formget[%hCanvas,.,controls]
gosub check

:: Verify pasted control has new unique ID (Label2, not Label1_copy1)
set _json=%@formget[%hCanvas,.,controllist]
set _jrc=%@jsoninput[%_json]
set _jn=%@jsonnodes[/json/items/]
set _lastid=%@unquote[%@jsonxpath[/json/items/[%_jn]/id/]]
set _jrc=%@jsonreset[]

set _tname=pasted control has unique ID (not Label1)
set _expect=0
iff "%_lastid" == "Label1" then
  set _actual=1
else
  set _actual=0
endiff
gosub check

set _tname=pasted ID is Label2
set _expect=Label2
set _actual=%_lastid
gosub check
echo.

:: ==================== Test: Copy/Paste container with children ====================
echo --- copy/paste container ---
gosub clear_canvas

:: Add a panel with two children
set RC=%@formadd[%hCanvas,Panel1,PANEL,20,20,200,150,]
set RC=%@formadd[%hCanvas,Panel1/btn1,BUTTON,10,10,80,28,Inside]
set RC=%@formadd[%hCanvas,Panel1/lbl1,LABEL,10,50,100,20,Child Label]

set _tname=canvas has 1 top-level control (Panel1)
set _expect=1
set _actual=%@formget[%hCanvas,.,controls]
gosub check

:: Copy Panel1 (should include children)
set RC=%@formset[%hCanvas,.,clipcopy,Panel1]

:: Paste
set RC=%@formset[%hCanvas,.,clippaste,]

set _tname=canvas has 2 top-level controls after paste
set _expect=2
set _actual=%@formget[%hCanvas,.,controls]
gosub check

:: Verify pasted panel has new ID
set _json=%@formget[%hCanvas,.,controllist]
set _jrc=%@jsoninput[%_json]
set _pastedid=%@unquote[%@jsonxpath[/json/items/[2]/id/]]
set _jrc=%@jsonreset[]

set _tname=pasted panel is Panel2 (not Panel1)
set _expect=Panel2
set _actual=%_pastedid
gosub check
echo.

:: ==================== Test: Cut removes control ====================
echo --- cut ---
gosub clear_canvas
gosub add_test_controls

set _tname=canvas has 3 controls before cut
set _expect=3
set _actual=%@formget[%hCanvas,.,controls]
gosub check

:: Cut Edit1
set RC=%@formset[%hCanvas,.,clipcut,Edit1]

set _tname=canvas has 2 controls after cut
set _expect=2
set _actual=%@formget[%hCanvas,.,controls]
gosub check

:: Paste the cut control back
set RC=%@formset[%hCanvas,.,clippaste,]

set _tname=canvas has 3 controls after paste
set _expect=3
set _actual=%@formget[%hCanvas,.,controls]
gosub check
echo.

:: ==================== Test: Multiple pastes get unique IDs ====================
echo --- multiple paste unique IDs ---
gosub clear_canvas
set RC=%@formadd[%hCanvas,Button1,BUTTON,20,20,80,28,Button]

set RC=%@formset[%hCanvas,.,clipcopy,Button1]
set RC=%@formset[%hCanvas,.,clippaste,]
set RC=%@formset[%hCanvas,.,clippaste,]
set RC=%@formset[%hCanvas,.,clippaste,]

set _tname=canvas has 4 controls after 3 pastes
set _expect=4
set _actual=%@formget[%hCanvas,.,controls]
gosub check

:: Check all IDs are unique via controllist
set _json=%@formget[%hCanvas,.,controllist]
set _jrc=%@jsoninput[%_json]
set _id1=%@unquote[%@jsonxpath[/json/items/[1]/id/]]
set _id2=%@unquote[%@jsonxpath[/json/items/[2]/id/]]
set _id3=%@unquote[%@jsonxpath[/json/items/[3]/id/]]
set _id4=%@unquote[%@jsonxpath[/json/items/[4]/id/]]
set _jrc=%@jsonreset[]

set _tname=first control is Button1
set _expect=Button1
set _actual=%_id1
gosub check

set _tname=second control is Button2
set _expect=Button2
set _actual=%_id2
gosub check

set _tname=third control is Button3
set _expect=Button3
set _actual=%_id3
gosub check

set _tname=fourth control is Button4
set _expect=Button4
set _actual=%_id4
gosub check
echo.

:: ==================== Test: Arrow key nudge ====================
echo --- arrow key nudge ---
gosub clear_canvas
set RC=%@formadd[%hCanvas,NudgeBtn,BUTTON,40,40,80,28,Nudge]

set _tname=NudgeBtn initial x=40
set _expect=40
set _actual=%@formget[%hCanvas,NudgeBtn,x]
gosub check

:: Nudge right by grid size (default 8)
set RC=%@formset[%hCanvas,NudgeBtn,moveby,8:0]

set _tname=NudgeBtn after nudge right x=48
set _expect=48
set _actual=%@formget[%hCanvas,NudgeBtn,x]
gosub check

:: Nudge down
set RC=%@formset[%hCanvas,NudgeBtn,moveby,0:8]

set _tname=NudgeBtn after nudge down y=48
set _expect=48
set _actual=%@formget[%hCanvas,NudgeBtn,y]
gosub check
echo.

:: ==================== Test: Cut preserves original ID on paste ====================
echo --- cut preserves ID ---
gosub clear_canvas
set RC=%@formadd[%hCanvas,MyButton,BUTTON,20,20,80,28,Test]

set RC=%@formset[%hCanvas,.,clipcut,MyButton]

set _tname=canvas empty after cut
set _expect=0
set _actual=%@formget[%hCanvas,.,controls]
gosub check

set RC=%@formset[%hCanvas,.,clippaste,]

set _tname=pasted control reuses original ID
set _expect=MyButton
set _json=%@formget[%hCanvas,.,controllist]
set _jrc=%@jsoninput[%_json]
set _actual=%@unquote[%@jsonxpath[/json/items/[1]/id/]]
set _jrc=%@jsonreset[]
gosub check
echo.

:: ==================== Test: Multi-select copy/paste ====================
echo --- multi-select copy/paste ---
gosub clear_canvas
set RC=%@formadd[%hCanvas,Label1,LABEL,20,20,100,20,Label]
set RC=%@formadd[%hCanvas,Button1,BUTTON,20,60,80,28,Button]

:: Select both via simulated clicks
set RC=%@formsimulate[%hCanvas,Label1,mousedown,10:10]
set RC=%@formsimulate[%hCanvas,Label1,mouseup,10:10]
delay /m 200

set _tname=canvas has 2 controls before multi-copy
set _expect=2
set _actual=%@formget[%hCanvas,.,controls]
gosub check

:: Copy all selected (empty value = use selectedall)
set RC=%@formset[%hCanvas,.,clipcopy,]

:: Paste
set RC=%@formset[%hCanvas,.,clippaste,]

set _tname=canvas has more controls after multi-paste
set _actual=%@formget[%hCanvas,.,controls]
iff %_actual gt 2 then
  set _tname=multi-paste added controls (count=%_actual)
  set _expect=1
  set _actual=1
else
  set _tname=multi-paste added controls
  set _expect=1
  set _actual=0
endiff
gosub check
echo.

:: ==================== Cleanup ====================
set RC=%@formset[%hCanvas,.,confirmclose,0]
set RC=%@formset[%hTool,.,confirmclose,0]
set RC=%@formset[%hProps,.,confirmclose,0]
set RC=%@formclose[%hCanvas]
set RC=%@formclose[%hTool]
set RC=%@formclose[%hProps]
set RC=%@formlog[off]
call "%REPO\examples\formcast-check.btm" unload

:: ==================== Results ====================
echo ============================================================
echo Results: %PASS passed, %FAIL failed, %TOTAL total
echo ============================================================
iff %FAIL gt 0 then
  endlocal & quit 1
else
  endlocal & quit 0
endiff

:fc_cleanup
  set RC=%@formlog[off]
  call "%REPO\examples\formcast-check.btm" unload
  endlocal
  quit 130
