:: ==================== Test: Align Left (functional) ====================
echo --- align left functional ---
gosub clear_canvas
gosub add_test_controls

:: Verify initial positions
set _tname=Label1 initial x=20
set _expect=20
set _actual=%@formget[%hCanvas,Label1,x]
gosub check

set _tname=Edit1 initial x=40
set _expect=40
set _actual=%@formget[%hCanvas,Edit1,x]
gosub check

set _tname=Button1 initial x=80
set _expect=80
set _actual=%@formget[%hCanvas,Button1,x]
gosub check

:: Single select align left: should align to canvas edge (x=0)
set RC=%@formset[%hCanvas,Label1,position,0:20]
set _tname=single align left moves to x=0
set _expect=0
set _actual=%@formget[%hCanvas,Label1,x]
gosub check
echo.

