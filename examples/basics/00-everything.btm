@echo off
setlocal
::
:: 00-everything.btm -- every visual control type, organized by tab
:: ================================================================
::
:: A tabbed showcase demonstrating all FormCast visual control types.
:: Each tab covers one category with generous spacing so nothing is
:: clipped. The form itself demonstrates MENUSTRIP, TOOLBAR, and
:: STATUSBAR as app chrome around the tabs.
::
:: Run with:
::   plugin /l C:\path\to\FormCast.dll
::   call 00-everything.btm
::

call "%_batchpath\..\formcast-check.btm" load

gosub render
goto after_render

:: ---- Build the form (called by main and by capture script) ----
:render
set h=%@formopen[form,everything,20,10,1060,780]
set RC=%@formset[%h,.,title,FormCast Control Showcase]
set RC=%@formset[%h,.,font,Segoe UI:11]

:: ============================================================
:: App chrome: toolbar first, then menu bar.
:: WinForms Dock.Top stacks in reverse addition order, so
:: the LAST added control docks closest to the top. Adding
:: the toolbar first and menu second puts the menu on top.
:: ============================================================
set RC=%@formadd[%h,tb,TOOLBAR,0,0,0,0,]
set RC=%@formadd[%h,tb/tbNew,BUTTON,0,0,0,0,New]
set RC=%@formset[%h,tb/tbNew,stockicon,new]
set RC=%@formadd[%h,tb/sep1,SEPARATOR,0,0,0,0,-]
set RC=%@formadd[%h,tb/tbOpen,BUTTON,0,0,0,0,Open]
set RC=%@formset[%h,tb/tbOpen,stockicon,open]
set RC=%@formadd[%h,tb/sep2,SEPARATOR,0,0,0,0,-]
set RC=%@formadd[%h,tb/tbSave,BUTTON,0,0,0,0,Save]
set RC=%@formset[%h,tb/tbSave,stockicon,save]

set RC=%@formadd[%h,menu,MENUSTRIP,0,0,0,0,]
set RC=%@formadd[%h,menu/file,LABEL,0,0,0,0,File]
set RC=%@formadd[%h,menu/file/new,LABEL,0,0,0,0,New]
set RC=%@formadd[%h,menu/file/open,LABEL,0,0,0,0,Open...]
set RC=%@formadd[%h,menu/file/save,LABEL,0,0,0,0,Save]
set RC=%@formadd[%h,menu/file/sep,LABEL,0,0,0,0,-]
set RC=%@formadd[%h,menu/file/exit,LABEL,0,0,0,0,Exit]
set RC=%@formadd[%h,menu/edit,LABEL,0,0,0,0,Edit]
set RC=%@formadd[%h,menu/edit/cut,LABEL,0,0,0,0,Cut]
set RC=%@formadd[%h,menu/edit/copy,LABEL,0,0,0,0,Copy]
set RC=%@formadd[%h,menu/edit/paste,LABEL,0,0,0,0,Paste]
set RC=%@formadd[%h,menu/help,LABEL,0,0,0,0,Help]
