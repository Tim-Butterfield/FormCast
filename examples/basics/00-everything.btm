:: ============================================================
:: Status bar
:: ============================================================
set RC=%@formadd[%h,sb,STATUSBAR,0,0,0,0,]
set RC=%@formadd[%h,sb/msg,LABEL,0,0,0,0,39 control types / 216 stock icons in FormCast v%@formversion[]]
set RC=%@formset[%h,sb/msg,spring,1]
set RC=%@formadd[%h,sb/ver,LABEL,0,0,0,0,Menu + Toolbar + StatusBar are always visible]
::  Status bar colors are set per-theme in :apply_theme
return

:after_render
:: ============================================================
:: Show and populate RichMemo (needs realized form)
:: ============================================================
set RC=%@formshow[%h]
gosub :fill_richmemo

:: ============================================================
:: Event bindings
:: ============================================================
:: Event loop: drain events via FORMEVENTS on the script
:: thread so gosub works. Toggle state is polled since
:: change events may not always queue reliably.
:: ============================================================
set _lastTheme=
set _lastDark=

:event_loop
  :: Poll toggles
  set _curTheme=%@formget[%h,tglTheme,checked]
  set _curDark=%@formget[%h,tglDark,checked]
  iff "%_curTheme" != "%_lastTheme" .or. "%_curDark" != "%_lastDark" then
    set _lastTheme=%_curTheme
    set _lastDark=%_curDark
    gosub :apply_theme
  endiff
  :: Drain queued click/close events
  do ev in /p formevents %h
    set _kind=%@word[1,%ev]
    set _ctrl=%@word[2,%ev]
    iff "%_kind" == "click" then
      if "%_ctrl" == "d3" gosub :on_click
      if "%_ctrl" == "exit" gosub :done
      if "%_ctrl" == "about" gosub :on_about
    endiff
    if "%_kind" == "close" gosub :done
  enddo
  delay /m 200
  goto :event_loop

:on_click
  set RC=%@formtaskdialog[Hello,You clicked the demo button!,ok,info]
return

:on_about
  set RC=%@formtaskdialog[About,FormCast Control Showcase -- demonstrating all 39 visual control types.,ok,info]
return

:apply_theme
  iff "%_curTheme" == "true" then
    iff "%_curDark" == "true" then
      set RC=%@formset[%h,.,theme,dark]
      set RC=%@formset[%h,tabs/basic/lblThemeStatus,text,Theme: dark]
      set RC=%@formset[%h,sb,backcolor,Highlight]
      set RC=%@formset[%h,sb/msg,forecolor,HighlightText]
      set RC=%@formset[%h,sb/ver,forecolor,HighlightText]
    else
      set RC=%@formset[%h,.,theme,light]
      set RC=%@formset[%h,tabs/basic/lblThemeStatus,text,Theme: light]
      set RC=%@formset[%h,sb,backcolor,Control]
      set RC=%@formset[%h,sb/msg,forecolor,ControlText]
      set RC=%@formset[%h,sb/ver,forecolor,ControlText]
    endiff
  else
    set RC=%@formset[%h,.,theme,system]
    set RC=%@formset[%h,tabs/basic/lblThemeStatus,text,Theme: system defaults]
    set RC=%@formset[%h,sb,backcolor,Control]
    set RC=%@formset[%h,sb/msg,forecolor,ControlText]
    set RC=%@formset[%h,sb/ver,forecolor,ControlText]
  endiff
  :: Re-populate RichMemo with theme-appropriate colors
  gosub :fill_richmemo
return

:fill_richmemo
  :: Clear and refill with colors appropriate for current theme
  set RC=%@formset[%h,tabs/text/richMemo,text,]
  iff "%_curTheme" == "true" .and. "%_curDark" == "true" then
    :: Dark mode: use light colors
    set RC=%@formset[%h,tabs/text/richMemo,appendstyle,Build Output Log|bold]
    set RC=%@formset[%h,tabs/text/richMemo,appendcolor,  [14:32:05] Compiling src/main.cs ...|LightSkyBlue]
    set RC=%@formset[%h,tabs/text/richMemo,appendcolor,  [14:32:06] Compiling src/utils.cs ...|LightSkyBlue]
    set RC=%@formset[%h,tabs/text/richMemo,appendcolor,  [14:32:06] Warning CS0168 in utils.cs line 42|#FFB347]
    set RC=%@formset[%h,tabs/text/richMemo,appendcolor,  [14:32:07] Compiling src/forms.cs ...|LightSkyBlue]
    set RC=%@formset[%h,tabs/text/richMemo,appendstyle,  Build succeeded. 1 warning(s).|bold]
  else
    :: Light/system mode: use standard colors
    set RC=%@formset[%h,tabs/text/richMemo,appendstyle,Build Output Log|bold]
    set RC=%@formset[%h,tabs/text/richMemo,appendcolor,  [14:32:05] Compiling src/main.cs ...|Blue]
    set RC=%@formset[%h,tabs/text/richMemo,appendcolor,  [14:32:06] Compiling src/utils.cs ...|Blue]
    set RC=%@formset[%h,tabs/text/richMemo,appendcolor,  [14:32:06] Warning CS0168 in utils.cs line 42|Orange]
    set RC=%@formset[%h,tabs/text/richMemo,appendcolor,  [14:32:07] Compiling src/forms.cs ...|Blue]
    set RC=%@formset[%h,tabs/text/richMemo,appendstyle,  Build succeeded. 1 warning(s).|bold]
  endiff
return

:done
  set RC=%@formclose[%h]
  call "%_batchpath\..\formcast-check.btm" unload
  endlocal & quit 0